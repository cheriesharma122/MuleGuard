# =====================================================
# MuleGuard - .gitignore
# Python | Streamlit | VS Code | Git
# =====================================================

##############################
# Python Bytecode
##############################

__pycache__/
*.py[cod]
*$py.class

##############################
# Compiled Extensions
##############################

*.so
*.pyd
*.dll

##############################
# Distribution / Packaging
##############################

build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

*.egg-info/
*.egg
.installed.cfg

##############################
# Virtual Environment
##############################

venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

##############################
# Environment Variables
##############################

.env
.env.*
!.env.example

##############################
# Streamlit
##############################

.streamlit/secrets.toml

##############################
# Logs
##############################

logs/
*.log
log.txt

##############################
# Generated Reports
##############################

*.pdf

# Uncomment if generated reports
# reports/

##############################
# Output Files
##############################

data/output/*
!data/output/.gitkeep

##############################
# Temporary Files
##############################

*.tmp
*.temp
*.bak
*.swp
*.swo

##############################
# Jupyter Notebook
##############################

.ipynb_checkpoints/

##############################
# VS Code
##############################

.vscode/
.history/

##############################
# PyCharm
##############################

.idea/

##############################
# OS Files
##############################

.DS_Store
Thumbs.db
desktop.ini

##############################
# Coverage & Testing
##############################

.coverage
coverage.xml
htmlcov/
.pytest_cache/
.tox/
.nox/

##############################
# MyPy
##############################

.mypy_cache/

##############################
# Ruff
##############################

.ruff_cache/

##############################
# Pyre
##############################

.pyre/

##############################
# Cython
##############################

cython_debug/

##############################
# Local Database
##############################

*.db
*.sqlite3

##############################
# Archives
##############################

*.zip
*.rar
*.7z
*.tar
*.gz

##############################
# Backup Files
##############################

*.old
*.orig
*.rej

##############################
# OneDrive Temporary Files
##############################

*.tmp
~$*

##############################
# Git Merge Files
##############################

*.orig

##############################
# Keep Important Project Folders
##############################

!data/input/
!screenshots/
!docs/
!research/
!tests/